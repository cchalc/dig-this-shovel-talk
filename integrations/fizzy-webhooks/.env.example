# Fizzy Webhook Configuration
# Copy this to .env and fill in your values

# Fizzy webhook signing secret (from Fizzy webhook settings)
FIZZY_SIGNING_SECRET=your_signing_secret_here

# GitHub Personal Access Token (needs repo and project scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=cchalc
GITHUB_PROJECT_ID=2

# Twilio WhatsApp Configuration
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp numbers (include whatsapp: prefix)
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890

# Server configuration
PORT=8080
